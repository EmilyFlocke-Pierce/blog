---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /** When set (e.g. Signal post), used for meta author and article:author so crawlers/fetchers attribute the post to the actual author, not the site owner. */
  author?: string;
}
const { title, description = 'A blog.', ogImage, author } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Emily Flocke</title>
  <meta name="description" content={description || title} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Favicon & logo -->
  <link rel="icon" type="image/png" href="/eth-icon.png" />
  <link rel="apple-touch-icon" href="/eth-icon.png" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description || title} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content={author ? "article" : "website"} />
  {author && <meta property="article:author" content={author} />}
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- Semantic author: so crawlers/fetchers attribute the post to the actual author (e.g. Alex), not the site owner -->
  {author && <meta name="author" content={author} />}

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="Emily Flocke" href="/rss.xml" />
</head>
<body>
  <header>
    <div class="container">
      <div class="site-header">
        <a href="/" class="site-name">
          <img src="/eth-icon.png" alt="" class="site-logo" width="28" height="28" />
          Emily Flocke
        </a>
        <nav>
          <a href="/thoughts">/thoughts</a>
          <a href="/signal">Signal</a>
          <a href="/read">Read</a>
          <a href="/assembly">Assembly</a>
          <a href="/about">About</a>
          <a href="/settings" class="nav-settings" aria-label="Settings">
            <svg class="nav-settings-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1Z" />
            </svg>
          </a>
        </nav>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <div class="container">
      <p>© {new Date().getFullYear()} Emily Flocke · <a href="/rss.xml">RSS</a> · <a href="/llms.txt">llms.txt</a></p>
    </div>
  </footer>

  <script>
    (function() {
      const KEYS = { fontSize: 'a11y-font-size', fontFamily: 'a11y-font-family', highContrast: 'a11y-high-contrast', reduceMotion: 'a11y-reduce-motion', focus: 'a11y-focus' };
      const DEFAULTS = { fontSize: 'medium', fontFamily: 'system', highContrast: 'off', reduceMotion: 'off', focus: 'default' };
      try {
        const s = {
          fontSize: localStorage.getItem(KEYS.fontSize) || DEFAULTS.fontSize,
          fontFamily: localStorage.getItem(KEYS.fontFamily) || DEFAULTS.fontFamily,
          highContrast: localStorage.getItem(KEYS.highContrast) || DEFAULTS.highContrast,
          reduceMotion: localStorage.getItem(KEYS.reduceMotion) || DEFAULTS.reduceMotion,
          focus: localStorage.getItem(KEYS.focus) || DEFAULTS.focus,
        };
        document.body.setAttribute('data-font-size', s.fontSize);
        document.body.setAttribute('data-font-family', s.fontFamily);
        document.body.setAttribute('data-high-contrast', s.highContrast);
        document.body.setAttribute('data-reduce-motion', s.reduceMotion);
        document.body.setAttribute('data-focus', s.focus);
      } catch (_) {}
    })();
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';

  header {
    border-bottom: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .site-name {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.1rem;
    font-weight: bold;
    color: var(--color-text);
    text-decoration: none;
  }
  .site-logo {
    flex-shrink: 0;
    border-radius: 4px;
    vertical-align: middle;
  }

  nav { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  nav a { color: var(--color-muted); font-size: 0.95rem; }
  nav a:hover { color: var(--color-text); text-decoration: none; }
  .nav-settings { display: inline-flex; align-items: center; color: var(--color-muted); }
  .nav-settings:hover { color: var(--color-text); }
  .nav-settings-icon { flex-shrink: 0; }
  footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    margin-top: 4rem;
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  main { padding: 3rem 0; }
</style>
