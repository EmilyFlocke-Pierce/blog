---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description = 'A blog.', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Emily the Human</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="Emily the Human" href="/rss.xml" />
</head>
<body>
  <header>
    <div class="container">
      <div class="site-header">
        <a href="/" class="site-name">Emily the Human</a>
        <nav>
          <a href="/on-learning">On Learning</a>
          <a href="/working-on">Working On</a>
          <a href="/signal">Signal</a>
          <a href="/about">About</a>
          <button type="button" id="easier-reading-btn" class="a11y-btn" aria-pressed="false" aria-label="Toggle easier reading (dyslexia-friendly font and spacing)">Easier reading</button>
        </nav>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <div class="container">
      <p>© {new Date().getFullYear()} Emily Flocke · <a href="/rss.xml">RSS</a> · <a href="/llms.txt">llms.txt</a></p>
    </div>
  </footer>

  <script>
    (function() {
      const STORAGE_KEY = 'easier-reading';
      const btn = document.getElementById('easier-reading-btn');
      function isOn() { return document.body.classList.contains('easier-reading'); }
      function apply(saved) {
        if (saved) {
          document.body.classList.add('easier-reading');
          if (btn) { btn.setAttribute('aria-pressed', 'true'); btn.textContent = 'Easier reading on'; }
        } else {
          document.body.classList.remove('easier-reading');
          if (btn) { btn.setAttribute('aria-pressed', 'false'); btn.textContent = 'Easier reading'; }
        }
      }
      try {
        const saved = localStorage.getItem(STORAGE_KEY) === 'on';
        apply(saved);
      } catch (_) {}
      if (btn) {
        btn.addEventListener('click', function() {
          const next = !isOn();
          try { localStorage.setItem(STORAGE_KEY, next ? 'on' : 'off'); } catch (_) {}
          apply(next);
        });
      }
    })();
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';

  header {
    border-bottom: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .site-name {
    font-size: 1.1rem;
    font-weight: bold;
    color: var(--color-text);
    text-decoration: none;
  }

  nav { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  nav a { color: var(--color-muted); font-size: 0.95rem; }
  nav a:hover { color: var(--color-text); text-decoration: none; }
  .a11y-btn {
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    font-size: 0.9rem;
    padding: 0.35rem 0.65rem;
    border-radius: 4px;
    cursor: pointer;
  }
  .a11y-btn:hover { color: var(--color-text); border-color: var(--color-signal); }
  .a11y-btn[aria-pressed="true"] { border-color: var(--color-signal); color: var(--color-signal); }

  footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    margin-top: 4rem;
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  main { padding: 3rem 0; }
</style>
