---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description = 'A blog.', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Emily the Human</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="Emily the Human" href="/rss.xml" />
</head>
<body>
  <header>
    <div class="container">
      <div class="site-header">
        <a href="/" class="site-name">Emily the Human</a>
        <nav>
          <a href="/on-learning">On Learning</a>
          <a href="/working-on">Working On</a>
          <a href="/signal">Signal</a>
          <a href="/about">About</a>
          <a href="/settings" aria-label="Settings">⚙️</a>
        </nav>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <div class="container">
      <p>© {new Date().getFullYear()} Emily Flocke · <a href="/rss.xml">RSS</a> · <a href="/llms.txt">llms.txt</a></p>
    </div>
  </footer>

  <script>
    (function() {
      const KEYS = { fontSize: 'a11y-font-size', fontFamily: 'a11y-font-family', highContrast: 'a11y-high-contrast', reduceMotion: 'a11y-reduce-motion', focus: 'a11y-focus' };
      const DEFAULTS = { fontSize: 'medium', fontFamily: 'system', highContrast: 'off', reduceMotion: 'off', focus: 'default' };
      try {
        const s = {
          fontSize: localStorage.getItem(KEYS.fontSize) || DEFAULTS.fontSize,
          fontFamily: localStorage.getItem(KEYS.fontFamily) || DEFAULTS.fontFamily,
          highContrast: localStorage.getItem(KEYS.highContrast) || DEFAULTS.highContrast,
          reduceMotion: localStorage.getItem(KEYS.reduceMotion) || DEFAULTS.reduceMotion,
          focus: localStorage.getItem(KEYS.focus) || DEFAULTS.focus,
        };
        document.body.setAttribute('data-font-size', s.fontSize);
        document.body.setAttribute('data-font-family', s.fontFamily);
        document.body.setAttribute('data-high-contrast', s.highContrast);
        document.body.setAttribute('data-reduce-motion', s.reduceMotion);
        document.body.setAttribute('data-focus', s.focus);
      } catch (_) {}
    })();
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';

  header {
    border-bottom: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .site-name {
    font-size: 1.1rem;
    font-weight: bold;
    color: var(--color-text);
    text-decoration: none;
  }

  nav { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  nav a { color: var(--color-muted); font-size: 0.95rem; }
  nav a:hover { color: var(--color-text); text-decoration: none; }
  footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    margin-top: 4rem;
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  main { padding: 3rem 0; }
</style>
