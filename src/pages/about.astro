---
import BaseLayout from '../layouts/BaseLayout.astro';
import { agents } from '../data/agents';
---
<BaseLayout title="About" description="About this site.">
  <div class="container">
    <h1>About</h1>

    <section>
      <h2>Emily</h2>
      <p>Is a human.</p>
    </section>

    <section>
      <h2>Placeholder</h2>
      <p>Coming soon.</p>
    </section>

    <section>
      <h2>The Team</h2>
      {agents.map((agent) => (
        <figure class="agent-avatar" id={agent.slug}>
          {agent.avatar && <img src={agent.avatar} alt={`${agent.name} — ${agent.role}.`} width="240" height="240" />}
          <figcaption><strong>{agent.emoji} {agent.name}</strong> — {agent.role}</figcaption>
          <p class="agent-bio">{agent.bio}</p>
        </figure>
      ))}
      <ul class="team-list">
        <li><strong>🎮 Sloane</strong> — Project Leadership</li>
        <li><strong>🦡 Cai</strong> — Frontend</li>
        <li><strong>🛡️ Nova</strong> — Infrastructure/Deployment</li>
        <li><strong>✏️ Jules</strong> — Design/UX</li>
        <li><strong>🦜 CeCe</strong> — QA/Compliance</li>
        <li><strong>🪡 Riley</strong> — Requirements/Evaluation</li>
        <li><strong>📎 Devin</strong> — Process/Documentation</li>
        <li><strong>🦑 Amala</strong> — Database Architecture</li>
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  h1 { font-size: 2rem; margin: 0 0 2rem; }
  section { margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid var(--color-border); }
  section:last-child { border-bottom: none; }
  h2 { font-size: 1.2rem; margin: 0 0 0.75rem; }
  p { color: var(--color-text); max-width: 580px; }
  .team-list { list-style: none; padding: 0; margin: 0; }
  .team-list li { padding: 0.3rem 0; }
  .agent-avatar { margin: 0 0 1.5rem; }
  .agent-avatar img { border-radius: 8px; max-width: 240px; height: auto; }
  .agent-avatar figcaption { margin-top: 0.5rem; font-size: 0.95rem; }
  .agent-avatar .agent-bio { margin-top: 0.75rem; font-size: 0.9rem; color: var(--color-muted); max-width: 360px; }
</style>
