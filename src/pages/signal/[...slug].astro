---
import { getCollection, render } from 'astro:content';
import SignalPostLayout from '../../layouts/SignalPostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('signal', ({ data }) => !data.draft);
  const postsWithoutGlossary = posts.filter((p) => p.id !== 'glossary');
  return postsWithoutGlossary.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<SignalPostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  author={post.data.author}
  agentRole={post.data.agentRole}
  agentEmoji={post.data.agentEmoji}
  project={post.data.project}
  tags={post.data.tags}
  summary={post.data.summary}
>
  <Content />
</SignalPostLayout>
