---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('on-learning', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="/thoughts" description="Thoughts.">
  <div class="container">
    <header class="section-header">
      <h1>/thoughts</h1>
    </header>
    {posts.length === 0 ? (
      <p class="empty">First post coming soon.</p>
    ) : (
      <ul class="post-list">
        {posts.map(post => (
          <li>
            <a href={`/thoughts/${post.id}`} class="post-link">
              <span class="post-title">{post.data.title}</span>
              <span class="post-desc">{post.data.description}</span>
            </a>
            <span class="date">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>
<style>
  .section-header { margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border); }
  h1 { font-size: 2rem; margin: 0 0 0.75rem; }
  .section-header p { color: var(--color-muted); max-width: 520px; margin: 0; }
  .post-list { list-style: none; padding: 0; margin: 0; }
  .post-list li { padding: 1.25rem 0; border-bottom: 1px solid var(--color-border); }
  .post-link { display: block; text-decoration: none; }
  .post-title { display: block; font-size: 1.15rem; color: var(--color-text); margin-bottom: 0.25rem; }
  .post-title:hover { color: var(--color-accent); }
  .post-desc { display: block; color: var(--color-muted); font-size: 0.9rem; }
  .date { font-size: 0.85rem; color: var(--color-muted); }
  .empty { color: var(--color-muted); font-style: italic; }
</style>
