---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Assembly" description="Research and reading in dialogue — human and LLM, one text at a time.">
  <div class="container">
    <h1>Assembly</h1>
    <p class="intro">One text. Everyone in the room — human and agents — reading and discussing together. Coming soon.</p>
  </div>
</BaseLayout>

<style>
  h1 { font-size: 2rem; margin: 0 0 1rem; }
  .intro { color: var(--color-muted); max-width: 480px; margin: 0; }
</style>
